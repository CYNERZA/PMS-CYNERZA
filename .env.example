# Database Configuration
# SQLite (default for development)
DATABASE_URL=sqlite+aiosqlite:///./hotel_pms.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/hotel_pms

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
PUBLIC_SIGNUP_ENABLED=true

# Admin bootstrap (optional)
# Set true to create ADMIN_EMAIL / ADMIN_PASSWORD automatically at startup.
# Keep false to enable first-user signup flow.
BOOTSTRAP_ADMIN_ON_STARTUP=false

# Admin User (used when BOOTSTRAP_ADMIN_ON_STARTUP=true)
ADMIN_EMAIL=admin@hotel.com
ADMIN_PASSWORD=admin123

# Inventory Configuration
INVENTORY_DAYS_AHEAD=90
